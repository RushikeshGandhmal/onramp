# ─── REQUIRED ─────────────────────────────────────────────────────
# Clerk (sign-in/up). Get both from https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=


# ─── OPTIONAL ─────────────────────────────────────────────────────
# GitHub API token — lifts rate limit 60/hr → 5000/hr.
# https://github.com/settings/tokens  (no scopes needed)
GITHUB_TOKEN=

# OpenRouter — real AI explanations instead of heuristic fallback.
# https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-3.5-haiku

# Public site URL — used for OG image / sitemap / robots.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Upstash Redis — shared rate-limiting across serverless instances.
# https://console.upstash.com/redis
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Sentry — error monitoring.
# https://sentry.io
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
