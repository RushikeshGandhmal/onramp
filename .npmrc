# Vercel and npm: use legacy peer-dep resolution.
#
# Why: @clerk/nextjs@7.x lists `next@^15` as a peer, but we run on Next 14
# (which Clerk supports in practice and which our middleware/types rely on).
# npm@7+ treats peer-dep mismatches as hard install errors. Vercel runs
# `npm install` without flags, so without this file the deploy fails with:
#   ERESOLVE could not resolve @clerk/nextjs ... peer next@^15
# `legacy-peer-deps=true` restores npm@6 behaviour: warn-but-install.
legacy-peer-deps=true
